# Mistral AI Configuration
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL_NAME=mistral-large-latest

# Pinecone Vector DB Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=nexora-career-index

# Supabase (PostgreSQL) Database URL
# Format: postgresql://[user]:[password]@[host]:5432/postgres
DATABASE_URL=postgresql://postgres.your_supabase_ref:your_password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
