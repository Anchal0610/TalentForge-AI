# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4-turbo # Default model for CrewAI agents

# Qdrant Configuration
# For Qdrant Cloud: URL starting with https:// and api_key
# For local instance: URL like http://localhost:6333 or ':memory:' for transient storage
QDRANT_URL=:memory:
QDRANT_API_KEY=

# Mistral Configuration (OCR)
MISTRAL_API_KEY=your_mistral_api_key_here

# SQLite Database path
DATABASE_URL=sqlite:///nexora_career.db
