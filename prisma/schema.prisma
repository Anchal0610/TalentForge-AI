datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String            @unique
  target_role     String?
  readiness_score Float             @default(0.0)
  created_at      DateTime          @default(now())
  resumes         Resume[]
  interviews      MockInterview[]
  sessions        PipelineSession[]
}

model Resume {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id       String   @db.ObjectId
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  filename      String
  file_url      String?
  raw_text      String
  ats_score     Float
  skills_json   Json?
  insights_json Json?
  created_at    DateTime @default(now())
}

model Document {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  filename    String
  file_url    String?
  chunk_count Int      @default(0)
  created_at  DateTime @default(now())
}

model MockInterview {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id        String   @db.ObjectId
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  topic          String
  role           String
  questions_json Json
  answers_json   Json
  score          Float
  created_at     DateTime @default(now())
}

model PipelineSession {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  email      String   @unique
  user       User     @relation(fields: [email], references: [email], onDelete: Cascade)
  data       Json     // Stores the full unified pipeline result JSON
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
